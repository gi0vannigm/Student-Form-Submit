<h1>New student</h1>

<%= form_with model: @student do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
    
  </div>

  <div>
    <%= form.label :email %>
    <%= form.email_field :email %>
  </div>

  <div>
    <%= form.label :grade %>
    <%= form.text_field :grade %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>

<%= form_with url: import_students_path, local: true, multipart: true do |form| %>
  <div>
    <p>Or, upload a CSV file:</p>
    <%= form.file_field :file, accept: ".csv" %>
  </div>
  <br>
  <div>
    <%= form.submit "Upload CSV" %>
  </div>
<% end %>
